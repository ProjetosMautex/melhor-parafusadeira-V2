---

<Layout title="Blog - Melhor Parafusadeira">
	<main>
		<header class="blog-header">
			<div class="container">
				<a href="/" class="back-link">&larr; Voltar para Home</a>
				<h1 class="animate-fade-in">Blog de <br/><span class="text-gradient">Ferramentas</span></h1>
				<p class="animate-fade-in" style="animation-delay: 0.2s">
					As últimas novidades, dicas de uso e revisões detalhadas.
				</p>
			</div>
		</header>

		<section class="articles-grid container">
			<div class="grid">
				{articles.map((article, index) => (
					<ArticleCard 
						title={article.title} 
						href={article.href} 
						image={article.image}
						delay={`${index * 0.1}s`}
					/>
				))}
			</div>
		</section>
	</main>

	<footer class="container">
		<p>&copy; 2026 Melhor Parafusadeira. Todos os direitos reservados.</p>
	</footer>
</Layout>

<style>
	main {
		padding-bottom: 5rem;
	}

	.blog-header {
		padding: 6rem 0 3rem;
		text-align: center;
	}

	.back-link {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.875rem;
		display: inline-block;
		margin-bottom: 1rem;
		transition: color 0.3s ease;
	}

	.back-link:hover {
		color: var(--primary);
	}

	h1 {
		font-size: clamp(2rem, 6vw, 3.5rem);
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}

	.text-gradient {
		background: linear-gradient(to right, var(--primary), #fff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	p {
		font-size: 1.125rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2rem;
	}

	footer {
		margin-top: auto;
		padding: 4rem 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		text-align: center;
		color: var(--text-muted);
		font-size: 0.875rem;
	}

	@media (max-width: 768px) {
		.blog-header {
			padding: 4rem 0 2rem;
		}
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
